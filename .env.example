# Переменные окружения для production
# Скопируйте этот файл в .env и заполните своими значениями
# НЕ КОММИТИТЬ .env В GIT!

# Секретный ключ для JWT токенов (сгенерируйте свой)
SECRET_KEY=your-secret-key-here-change-me

# Секретный ключ для подписи (сгенерируйте свой)
SIGN_SECRET=your-sign-secret-here-change-me

# Подключение к базе данных
DATABASE_URL=postgresql://postgres:your-password@localhost/asbr

# Базовый URL сайта (используется для генерации QR-ссылок)
BASE_URL=https://your-domain.example.com

# CORS настройки (через запятую)
CORS_ORIGINS=https://your-domain.example.com,http://localhost:3000

# Путь к хранилищу файлов
DATA_ROOT=/home/instr/app/storage

# Режим отладки (true/false)
DEBUG=false

# Время жизни JWT токена (в минутах)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Максимальное количество попыток входа
MAX_LOGIN_ATTEMPTS=5

# Время блокировки после превышения попыток (в минутах)
BLOCK_DURATION_MINUTES=15

# Sentry DSN для мониторинга ошибок (получите на sentry.io)
# SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/123456

# Окружение для Sentry (development/staging/production)
ENVIRONMENT=production

# OpenAI API ключ для генерации AI-вопросов по инструктажам
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Telegram бот для алертов мониторинга (monitor.py)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Настройки AI вопросов
AI_QUESTIONS_ENABLED=true
AI_QUESTIONS_COUNT=4
AI_QUESTIONS_PASS_THRESHOLD=75
