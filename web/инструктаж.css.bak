/* ================================================================
   инструктаж.css — стили страницы электронного инструктажа
   ================================================================ */

/* ─── Сброс и базовые ─────────────────────────────────────────── */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html, body { height: 100%; }
body {
  font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
  background: #f2f5fa;
  color: #1f2937;
  display: flex;
  flex-direction: column;
  line-height: 1.5;
}
button { cursor: pointer; font-family: inherit; }

/* ─── Шапка ───────────────────────────────────────────────────── */
header {
  background: #f2f5fa;
  border-bottom: 2px solid #5b9bd5;
  position: sticky;
  top: 0;
  z-index: 100;
}
.header-flex {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 16px;
}
.header-logo img { height: 56px; }
.header-title { flex: 1; text-align: center; }
.header-title h1 { font-size: 26px; color: #5b9bd5; font-weight: 700; }
.header-login-container { display: flex; align-items: center; gap: 8px; }

/* ─── Кнопки и инпуты ─────────────────────────────────────────── */
.header-input {
  height: 36px;
  padding: 8px 10px;
  border: 1px solid #cbd5e1;
  border-radius: 8px;
  background: #fff;
  font-size: 16px; /* 16px — предотвращает zoom на iOS */
  transition: border-color 0.15s;
}
.header-input:focus { outline: none; border-color: #5b9bd5; }

.header-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 44px;
  min-height: 44px;
  padding: 0 16px;
  border: none;
  border-radius: 8px;
  background: #5b9bd5;
  color: #fff;
  font-weight: 600;
  font-size: 15px;
  white-space: nowrap;
  text-decoration: none;
  transition: background 0.15s, transform 0.1s;
}
.header-btn:hover { background: #468ec9; }
.header-btn:active { background: #3a6db8; transform: scale(0.98); }
.header-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

/* ─── Основной layout ─────────────────────────────────────────── */
.main { flex: 1; display: flex; min-height: 0; }

.left {
  width: 220px;
  padding: 16px;
  border-right: 2px solid #5b9bd5;
  background: #f2f5fa;
  flex-shrink: 0;
}
.left h3 { font-size: 16px; font-weight: 700; margin-bottom: 10px; color: #1f365c; }

.category-btn {
  display: block;
  width: 100%;
  margin-bottom: 8px;
  padding: 10px 14px;
  border: none;
  border-radius: 8px;
  background: #5b9bd5;
  color: #fff;
  font-size: 15px;
  font-weight: 500;
  text-align: left;
  transition: background 0.15s, transform 0.1s;
}
.category-btn:hover { background: #468ec9; }
.category-btn:active { transform: scale(0.98); }
.category-btn.active-button { background: #1e3a5f; }

.right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 16px;
  min-width: 0;
  overflow-y: auto;
}

/* ─── Навигация по месяцам ─────────────────────────────────────── */
.month-toolbar {
  display: none;
  align-items: center;
  gap: 12px;
  justify-content: center;
  margin: 8px 0;
  position: sticky;
  top: 0;
  z-index: 50;
  background: #f2f5fa;
  padding: 10px;
  border-radius: 12px;
  border: 1px solid #e0e6f0;
  box-shadow: 0 1px 4px rgba(0,0,0,.05);
}
.btn-big {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 48px;
  height: 48px;
  font-size: 22px;
  border: 1px solid #5b9bd5;
  border-radius: 10px;
  background: #5b9bd5;
  color: #fff;
  transition: background 0.15s;
}
.btn-big:hover { background: #468ec9; }
.month-pretty {
  min-width: 220px;
  height: 48px;
  line-height: 48px;
  padding: 0 12px;
  border: 1px solid #c8d7ee;
  border-radius: 10px;
  background: #fff;
  font-size: 22px;
  font-weight: 700;
  text-align: center;
  color: #1f365c;
  user-select: none;
}

/* ─── Карточки файлов ──────────────────────────────────────────── */
.file-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 12px;
}
.file-card {
  background: #fff;
  border: 1px solid #e0e6f0;
  border-radius: 12px;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  transition: box-shadow 0.15s, border-color 0.15s;
}
.file-card:hover { box-shadow: 0 4px 16px rgba(91,155,213,.12); border-color: #c3d9f0; }
.file-card.completed {
  opacity: 0.55;
  pointer-events: none;
  position: relative;
}
.file-card.completed::after {
  content: '✓';
  position: absolute;
  top: 8px;
  right: 8px;
  background: #22c55e;
  color: #fff;
  font-size: 12px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 6px;
}
.file-card .title {
  font-weight: 600;
  color: #1f365c;
  font-size: 14px;
  word-break: break-word;
  flex: 1;
}
.badge-done {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 6px;
  background: #22c55e;
  color: #fff;
  font-weight: 700;
  font-size: 13px;
}

/* ─── Приветственное сообщение ─────────────────────────────────── */
#welcomeMessage {
  text-align: center;
  padding: 80px 20px;
  color: #6b7280;
}
#welcomeMessage .icon { font-size: 48px; margin-bottom: 16px; }
#welcomeMessage .title-text { font-size: 20px; font-weight: 600; color: #374151; margin-bottom: 6px; }
#welcomeMessage .sub-text { font-size: 14px; color: #9ca3af; }

/* ─── Простая форма (вводный/первичный) ─────────────────────────── */
#simpleForm {
  display: none;
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 20px;
  max-width: 960px;
  margin: 12px auto;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
#simpleForm label {
  display: block;
  font-size: 13px;
  color: #374151;
  font-weight: 500;
  margin-bottom: 4px;
  margin-top: 10px;
}
#simpleForm label:first-child { margin-top: 0; }
#simpleForm .header-input { width: 100%; margin-bottom: 0; }
#simpleForm .form-right canvas {
  width: 100%;
  height: 150px;
  border: 1px solid #cbd5e1;
  border-radius: 8px;
  display: block;
}
#simpleForm .form-right button { margin-top: 8px; }
#simpleForm h2 { font-size: 18px; color: #1f365c; margin-bottom: 4px; }

/* ─── Канвас для подписи ───────────────────────────────────────── */
#canvas, #simpleCanvasEmp, #simpleCanvasInstr {
  touch-action: none;
  cursor: crosshair;
  -webkit-user-select: none;
  user-select: none;
  display: block;
}

/* ─── Модальное окно просмотра ─────────────────────────────────── */
#viewer.modal {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, .55);
  display: none;
  align-items: center;
  justify-content: center;
  padding: 0;
}
#viewer.modal.open { display: flex; }

.viewer-panel {
  background: #fff;
  width: 100%;
  max-width: 1200px;
  margin: auto;
  border-radius: 14px;
  display: flex;
  flex-direction: column;
  height: 90vh;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0, 0, 0, .25);
}

.viewer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 14px;
  border-bottom: 1px solid #e5e7eb;
  gap: 8px;
  flex-shrink: 0;
  background: #fafbfc;
}
.viewer-title {
  font-weight: 700;
  color: #1f365c;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 15px;
}
.viewer-actions { display: flex; gap: 8px; }

.viewer-body {
  flex: 1;
  overflow-y: auto;
  display: flex;
  min-height: 0;
  -webkit-overflow-scrolling: touch;
  background: #f8f9fa;
}
#preview {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}
#preview iframe {
  width: 100%;
  flex: 1;
  height: 100%;
  border: none;
}
#preview video {
  width: 100%;
  height: auto;
  object-fit: contain;
}

.viewer-footer {
  flex-shrink: 0;
  overflow: hidden;
  padding: 10px 14px;
  border-top: 1px solid #e5e7eb;
  background: #fff;
  display: flex;
  flex-direction: column;
  gap: 0;
}
#footerScrollable {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  max-height: 38vh;
  padding-top: 8px;
}

/* Чекбокс "Ознакомлен" */
.ack-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 8px 0;
}
.ack-row input[type="checkbox"] {
  width: 28px;
  height: 28px;
  accent-color: #2b77d1;
  flex-shrink: 0;
  cursor: pointer;
}
.ack-row label {
  font-size: 17px;
  font-weight: 500;
  line-height: 1.3;
  user-select: none;
  cursor: pointer;
  color: #1f365c;
}

/* Блок теста */
#quizBlock {
  padding: 16px;
  background: #f8fafc;
  border: 1px solid #e0e6f0;
  border-radius: 10px;
}
#quizBlock h3 { font-size: 17px; color: #1f365c; }

/* Блок подписи */
#signatureBlock { margin-top: 12px; }
#signatureBlock label {
  display: block;
  font-size: 13px;
  font-weight: 500;
  color: #374151;
  margin-bottom: 6px;
}
#canvas {
  max-width: 100%;
  border: 1.5px solid #cbd5e1;
  border-radius: 8px;
  background: #fff;
}

/* DOCX */
.docx-container { padding: 24px; background: #fff; max-width: 100%; box-sizing: border-box; }
.docx-container section { max-width: 900px; margin: 0 auto; }
.docx-container table { border-collapse: collapse; }
.docx-container table td, .docx-container table th { border: 1px solid #d1d5db; padding: 4px; }

/* ─── Адаптив: Планшеты 768–1024px ────────────────────────────── */
@media (max-width: 1024px) {
  .main { flex-direction: column; }
  .left {
    width: 100%;
    border-right: none;
    border-bottom: 2px solid #5b9bd5;
    display: block !important;
    overflow-x: visible !important;
    padding: 12px;
  }
  .left h3 { display: block; margin-bottom: 12px; font-size: 17px; }
  .category-btn {
    display: block !important;
    width: 100% !important;
    margin: 0 0 10px 0 !important;
    white-space: normal !important;
    font-size: 16px;
    padding: 14px;
    min-height: 52px;
  }
  .header-login-container { flex-direction: row; align-items: center; gap: 8px; font-size: 15px; }
  .header-login-container .header-input { display: none; }
  .header-login-container .logout-btn { display: inline-flex; min-height: 44px; }
  .file-grid { grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
  .file-card { padding: 14px; }
  .file-card .header-btn { min-height: 48px; padding: 0 20px; font-size: 16px; }
  #simpleForm { padding: 16px; gap: 16px; }
  #simpleForm canvas { height: 220px !important; }
  #simpleForm .header-btn { min-height: 48px; font-size: 16px; }
  #simpleForm label { font-size: 15px; margin-top: 8px; }
  #canvas { height: 180px; }
  .viewer-footer { padding: 14px; }
  .ack-row { padding: 10px 0; }
  .ack-row input[type="checkbox"] { width: 36px; height: 36px; }
  .ack-row label { font-size: 17px; }
}

/* ─── Адаптив: Смартфоны до 768px ─────────────────────────────── */
@media (max-width: 768px) {
  .header-flex { padding: 8px 12px; flex-wrap: wrap; gap: 8px; }
  .header-title { flex-basis: 100%; order: 2; margin-top: 4px; }
  .header-title h1 { font-size: 15px; text-align: left; }
  .header-logo { order: 1; }
  .header-logo img { height: 42px; }
  .header-login-container { order: 3; flex: 1; justify-content: flex-end; font-size: 14px; gap: 6px; }
  .header-btn, .category-btn { min-height: 48px; padding: 12px 16px; font-size: 16px; }
  .header-input { min-height: 48px; font-size: 16px; }
  .file-grid { grid-template-columns: 1fr; gap: 12px; }
  .file-card { padding: 12px; }
  .file-card .header-btn { width: 100%; justify-content: center; }
  .left { padding: 12px; display: flex !important; flex-wrap: wrap; gap: 8px; justify-content: stretch; }
  .left h3 { display: none; }
  .category-btn { flex: 1 1 calc(50% - 4px); min-width: 140px; margin: 0 !important; }
  .viewer-panel { max-width: 100%; border-radius: 0; height: 100vh; }
  .viewer-title { font-size: 14px; }
  .viewer-header { padding: 10px 12px; }
  .viewer-header .header-btn { padding: 8px 14px; font-size: 15px; }
  .viewer-footer { padding: 12px; }
  #simpleForm { grid-template-columns: 1fr; gap: 12px; padding: 12px; }
  #simpleForm canvas { height: 280px !important; }
  #simpleForm .header-btn { width: 100%; justify-content: center; }
  #simpleForm label { font-size: 15px; font-weight: 600; margin-top: 8px; display: block; }
  .ack-row { padding: 12px 0; gap: 12px; }
  .ack-row input[type="checkbox"] { width: 40px; height: 40px; }
  .ack-row label { font-size: 17px; line-height: 1.4; }
  .month-toolbar { gap: 8px; padding: 10px; flex-wrap: wrap; }
  .btn-big { min-width: 52px; height: 52px; font-size: 24px; }
  .month-pretty { min-width: 200px; height: 52px; line-height: 52px; font-size: 18px; }
  #showDoneBtn { height: 52px; font-size: 15px; padding: 0 18px; }
  #welcomeMessage { padding: 60px 16px; }
}

/* ─── Landscape на планшетах ──────────────────────────────────── */
@media (min-width: 768px) and (max-width: 1024px) and (orientation: landscape) {
  .file-grid { grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); }
  .left { display: flex !important; flex-wrap: wrap; align-items: center; gap: 10px; padding: 10px 16px; }
  .left h3 { margin-right: auto; margin-bottom: 0; font-size: 16px; }
  .category-btn { flex: 0 0 auto; width: auto !important; padding: 12px 18px; margin: 0 !important; min-height: 48px; }
}

/* ─── Mini-tablets portrait ──────────────────────────────────── */
@media (min-width: 600px) and (max-width: 768px) and (orientation: portrait) {
  .file-grid { grid-template-columns: repeat(2, 1fr); }
  .file-card .header-btn { min-height: 48px; font-size: 15px; }
}

/* ─── Крошечные экраны < 400px ─────────────────────────────────── */
@media (max-width: 400px) {
  .header-title h1 { font-size: 14px; }
  .header-logo img { height: 38px; }
  .category-btn { font-size: 15px; padding: 10px 12px; }
  .file-card { padding: 10px; }
  .month-pretty { font-size: 16px; min-width: 160px; }
}

/* ─── Маленький чекбокс (только ack-row на mobile < 600px) ─────── */
@media (max-width: 600px) {
  .ack-row input[type="checkbox"] { width: 32px; height: 32px; }
  .ack-row label { font-size: 20px; }
}
